# Yosys synthesis script for Baud Generator

# 1. Read SystemVerilog design
read_verilog -sv rtl/baud_generator.sv

# 2. Check design hierarchy
hierarchy -check -top baud_generator

# 3. High-level synthesis
proc
opt
memory
opt
fsm
opt

# 4. Map to generic logic gates
techmap
opt

# 5. Print statistics
stat

# 6. Write synthesized netlist
write_verilog -noattr reports/baud_generator_synth.v