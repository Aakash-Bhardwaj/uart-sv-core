# Yosys synthesis script for UART Transmitter

# 1. Read SystemVerilog design
read_verilog -sv rtl/uart_rx.sv

# 2. Check design hierarchy
hierarchy -check -top uart_rx

# 3. High-level synthesis
proc
opt
memory
opt
fsm
opt

# 4. Map to generic logic gates
techmap
opt

# 5. Print statistics
stat

# 6. Write synthesized netlist
write_verilog -noattr reports/uart_rx_synth.v